{
  "name": "@teich/cli",
  "version": "0.0.1",
  "description": "CLI for teich local-first file sync",
  "type": "module",
  "main": "src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "bin": {
    "teich": "src/cli.ts"
  },
  "files": [
    "src",
    "!src/**/*.test.ts",
    "package.json"
  ],
  "scripts": {
    "dev": "bun --watch src/cli.ts",
    "dev:inspect": "bun --inspect --watch src/cli.ts",
    "start": "bun src/cli.ts",
    "test": "vitest run"
  },
  "dependencies": {
    "@evolu/common": "^7.4.0",
    "@teich/sync-invariants": "workspace:*",
    "@types/proper-lockfile": "^4.1.4",
    "chokidar": "^5.0.0",
    "citty": "^0.2.2",
    "env-paths": "^4.0.0",
    "picocolors": "^1.1.1",
    "picomatch": "^4.0.3",
    "proper-lockfile": "^4.1.2",
    "sql.js": "^1.13.0",
    "tsx": "^4.21.0",
    "untildify": "^6.0.0"
  },
  "devDependencies": {
    "@types/sql.js": "^1.4.9",
    "@types/picomatch": "^4.0.2",
    "vitest": "^4.1.0"
  },
  "engines": {
    "node": ">=22.6.0"
  },
  "keywords": [
    "file-sync",
    "local-first",
    "evolu",
    "crdt",
    "distributed",
    "sync",
    "offline-first"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/namjul/teich.git",
    "directory": "centers/cli"
  },
  "bugs": {
    "url": "https://github.com/namjul/teich/issues"
  },
  "homepage": "https://github.com/namjul/teich#readme",
  "license": "MIT"
}
